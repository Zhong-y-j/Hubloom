OPENAI_API_KEY=...                  # 通用 OpenAI API Key
OPENAI_MODEL=...                    # 通用 OpenAI 模型
OPENAI_BASE_URL=...                 # 通用 OpenAI 基础URL
OPENAI_TIMEOUT=180                  # 通用 OpenAI 超时时间

# 会话ID与存储
CORTEX_DEFAULT_SESSION_ID=mem:tester_id:default   # 开发自测会话ID，生产环境直接使用接口传入的用户ID作为会话ID
CORTEX_MEMORY_DB=data/memory.db                   # 对话历史存储路径
CORTEX_KB_DIR=data/knowledge_db                   # 知识库存储路径 

# 长期记忆（Qdrant episodic/semantic + Neo4j associative）；0/false 则仅 SQLite 对话历史；1/true 则开启长期记忆
CORTEX_ENABLE_LONG_TERM_MEMORY=0      # 是否开启长期记忆 

CORTEX_AGENT_LOG=1      # 是否开启Agent日志

# 搜索引擎API密钥
SERPAPI_API_KEY=...       # API密钥



# Qdrant 服务
QDRANT_URL=...           # 服务地址
QDRANT_API_KEY=...       # API密钥
QDRANT_COLLECTION=...    # 集合名称
NO_PROXY=localhost,127.0.0.1,.qdrant.io,qdrant.io,*.cloud.qdrant.io

# Neo4j 服务
NEO4J_URI=neo4j+s://...    # 数据库地址
NEO4J_USER=...             # 用户名
NEO4J_PASSWORD=...         # 密码
NEO4J_DATABASE=...         # 数据库名称
NEO4J_SKIP_DNS_CHECK=1     # 跳过 DNS 检查

# MCP / Swagger 适配（mcp_adapter/server.py）
MCP_SWAGGER_URL=...    # 用户服务Swagger URL 
MCP_BASE_URL=...                           # 用户服务基础URL
# 用户服务Token，生产环境由企业后端转发
MCP_TOKEN=...