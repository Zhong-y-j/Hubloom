.venv
venv
__pycache__/
*.py[cod]

.env
.env.*
!.env.example

# 本地 YAML 配置（含密钥）；模板保留 config/env.example.yaml
config/env.yaml
!config/env.example.yaml

# 运行时数据（memory.db、knowledge_db、chroma 等）
data/
# A2UI demo 场景数据（源码，非运行时库）
!examples/a2ui_demo/web/src/data/
!examples/a2ui_demo/web/src/data/**

# travel demo runtime sqlite
examples/travel/mocks/**/data/
examples/travel/scripts/.pids/
examples/travel/scripts/logs/

# 运行时日志（保留 logs/.gitkeep）
logs/*
!logs/.gitkeep

public/

.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

.mypy_cache/
.ruff_cache/

dist/
build/
node_modules/
*.egg-info/
.eggs/

.DS_Store
**/.DS_Store
# src 下误生成的运行日志
src/logs/
*.log

# 技能说明：跟踪公共 Skill；其它本地草案可忽略
/skills/*
!/skills/README.md
!/skills/hubloom/
!/skills/hubloom/**
!/skills/a2ui/
!/skills/a2ui/**
!/skills/account-access/
!/skills/account-access/**
!/skills/select-before-act/
!/skills/select-before-act/**
