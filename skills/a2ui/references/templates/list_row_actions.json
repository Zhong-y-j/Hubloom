[
  {
    "version": "v0.9.1",
    "createSurface": {
      "surfaceId": "listMain",
      "catalogId": "https://a2ui.org/specification/v0_9/catalogs/basic/catalog.json"
    }
  },
  {
    "version": "v0.9.1",
    "updateComponents": {
      "surfaceId": "listMain",
      "components": [
        {
          "id": "root",
          "component": "Column",
          "children": ["title", "list"]
        },
        {
          "id": "title",
          "component": "Text",
          "text": "请选择一项",
          "variant": "h2"
        },
        {
          "id": "list",
          "component": "List",
          "direction": "vertical",
          "children": { "componentId": "row", "path": "/items" }
        },
        { "id": "row", "component": "Card", "child": "row_body" },
        {
          "id": "row_body",
          "component": "Row",
          "children": ["row_info", "row_btn"],
          "justify": "spaceBetween",
          "align": "center"
        },
        {
          "id": "row_info",
          "component": "Column",
          "children": ["row_name", "row_desc"]
        },
        {
          "id": "row_name",
          "component": "Text",
          "text": { "path": "name" },
          "variant": "h3"
        },
        {
          "id": "row_desc",
          "component": "Text",
          "text": { "path": "description" },
          "variant": "caption"
        },
        { "id": "row_btn_label", "component": "Text", "text": "操作" },
        {
          "id": "row_btn",
          "component": "Button",
          "child": "row_btn_label",
          "action": {
            "event": {
              "name": "request_delete_item",
              "context": {
                "id": { "path": "id" },
                "name": { "path": "name" }
              }
            }
          }
        }
      ]
    }
  },
  {
    "version": "v0.9.1",
    "updateDataModel": {
      "surfaceId": "listMain",
      "path": "/items",
      "value": { "$hubloom_tool": { "path": "body.items" } }
    }
  }
]
